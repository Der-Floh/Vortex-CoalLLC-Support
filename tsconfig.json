{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2022",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "./out",
        "rootDir": ".",
        "declaration": false,
        "sourceMap": true,
        "inlineSources": true,
        "skipLibCheck": true,
        "types": [
            "node"
        ]
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "out",
        "Vortex"
    ]
}